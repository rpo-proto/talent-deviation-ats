# Public-safe example config. Copy to .env.local for your private machine.

# SQLite database path. Defaults to .local/talent.db.
TALENT_ATS_DB_PATH=.local/talent.db

# Export target for private operational artifacts.
TALENT_ATS_EXPORT_DIR=.local/exports

# Candidate profile packet target. Defaults beside the export folder when omitted.
TALENT_ATS_CANDIDATE_PACKET_DIR=.local/candidate-profiles

# Comma-separated local roots that the private file route may serve.
TALENT_ATS_ALLOWED_FILE_ROOTS=.local/artifacts,.local/candidate-profiles,.local/exports

# Optional private Drive folder URL shown in the app as the raw artifact vault.
TALENT_ATS_DRIVE_ROOT_URL=

# Clerk auth. Leave empty for local-only unauthenticated development.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
